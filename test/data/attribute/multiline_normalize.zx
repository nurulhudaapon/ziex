pub fn Page(allocator: zx.Allocator) zx.Component {
    const class_name = "container";

    return (
        <div @allocator={allocator}>
            <section
              class={class_name}
                        id="main"
          data-active="true"
            >
                <p>Messy indentation</p>
            </section>
            <input
              type="text"
                        class="input"
          placeholder="Enter text"
            />
        </div>
    );
}

const zx = @import("zx");
