// --- Learn: onclick ---
pub fn Learn__Interactivity(allocator: zx.Allocator) zx.Component {
    return (<Learn__EventHandling @{allocator} @rendering={.client} />);
}
pub fn Learn__EventHandling(allocator: zx.Allocator) zx.Component {
    return (
        <main @allocator={allocator}>
            <button onclick={Learn__handleClick}>Click me</button>
            <input oninput={Learn__handleInput} />
        </main>
    );
}

fn Learn__handleClick(_: zx.client.Event) void {
    zx.log.info("Clicked!", .{});
}

fn Learn__handleInput(event: zx.client.Event) void {
    const v = event.value() orelse "";
    zx.log.info("Input: {s}", .{v});
}

// --- Learn: onnull ---

// --- Reference Inline: attrs ---
pub fn unwrap__template_attrs() void {
    const count = 42;
    const name = "John";
    // ...
    _ = (
        <div class=`item-{count}` data-user=`user-{name}`>
            <a href=`/users/{name}/profile`>Profile</a>
        </div>
    );
    // Renders:
    //<div class="item-42" data-user="user-John">
    //  <a href="/users/John/profile">Profile</a>
    //</div>
}

// --- Reference Inline: expr string ---
pub fn unwrap__ref_expr_string() void {
    const name = "Alice";
    // ...
    _ = (<p>{name}</p>); // <p>Alice</p>
}

// --- Reference Inline: expr int ---
pub fn unwrap__ref_expr_int() void {
    const count: u32 = 42;
    // ...
    _ = (<p>{count}</p>); // <p>42</p>
}

// --- Reference Inline: expr float ---
pub fn unwrap__ref_expr_float() void {
    const price: f32 = 19.99;
    // ...
    _ = (<p>${price}</p>); // <p>$19.99</p>
}

// --- Reference Inline: expr bool ---
pub fn unwrap__ref_expr_bool() void {
    const active = true;
    // ...
    _ = (<p>{active}</p>); // <p>true</p>
}

// --- Reference Inline: expr enum ---
pub fn unwrap__ref_expr_enum() void {
    const Status = enum { pending, approved, rejected };
    const status = Status.approved;
    // ...
    _ = (<p>{status}</p>); // <p>approved</p>
}

// --- Reference Inline: expr optional ---
pub fn unwrap__ref_expr_optional() void {
    const maybe_name: ?[]const u8 = "Bob";
    // ...
    _ = (<p>{maybe_name}</p>); // <p>Bob</p>

    const no_name: ?[]const u8 = null;
    // ...
    _ = (<p>{no_name}</p>); // <p></p> (empty)
}

// --- Reference Inline: expr component ---
pub fn unwrap__ref_expr_component() void {
    const header = zx.Component{ .text = "Header" };
    // ...
    _ = (<div>{header}</div>); // Renders the Header component
}

// --- Reference Inline: expr component array ---
pub fn unwrap__ref_expr_component_array() void {
    const items: []const zx.Component = &.{ zx.Component{ .text = "A" }, zx.Component{ .text = "B" } };
    // ...
    _ = (<ul>{items}</ul>); // Renders both Item components
}

// --- Reference Inline: optional capture ---
pub fn unwrap__ref_optional_capture() void {
    const user_name: ?[]const u8 = "Alice";
    // ...
    _ = if (user_name) |name| (<p>Welcome, {name}!</p>);

    // With else branch:
    _ = if (user_name) |name| (<p>Hello, {name}</p>) else (<p>Guest</p>);

    // While with capture (iterator pattern):
    var maybe_item: ?[]const u8 = "item";
    _ = while (maybe_item) |item| : (maybe_item = null) (<li>{item}</li>);
}

// --- Reference Inline: error capture ---
pub fn unwrap__ref_error_capture() void {
    const parsed = std.fmt.parseInt(u32, "42", 10);

    // If with error capture:
    _ = if (parsed) |value| (<p>Value: {value}</p>) else |err| (<p>Error: {@errorName(err)}</p>);

    // While with error capture:
    var first = true;
    _ = while (parseOnceRefInline(&first)) |value| (<li>{value}</li>) else |err| (<p>Iteration ended: {@errorName(err)}</p>);
}

fn parseOnceRefInline(first: *bool) !u32 {
    if (first.*) {
        first.* = false;
        return 1;
    }
    return error.Done;
}

// --- Reference Inline: spread attrs ---
pub fn unwrap__ref_spread_attrs() void {
    const form_attrs = .{
        .class = "form-control",
        .@"data-validate" = "true",
    };
    const input_props = .{ .name = "email", .value = "test@example.com" };
    // ...
    _ = (
        <form {..form_attrs}>
            <input type="text" {..input_props} />
        </form>
    );
}

// --- Reference Inline: shorthand attrs ---
pub fn unwrap__ref_shorthand_attrs() void {
    const class = "btn-primary";
    const disabled = true;
    const @"data-id" = "123";
    _ = (<button {class} {disabled} {@"data-id"}>Click</button>);
    // Renders: <button class="btn-primary" disabled data-id="123">Click</button>
}

// --- Reference Inline: template attrs ---
pub fn unwrap__ref_template_attrs() void {
    const count = 42;
    const name = "John";
    // ...
    _ = (
        <div class=`item-{count}` data-user=`user-{name}`>
            <a href=`/users/{name}/profile`>Profile</a>
        </div>
    );
    // Renders:
    //<div class="item-42" data-user="user-John">
    //  <a href="/users/John/profile">Profile</a>
    //</div>
}

// --- Reference Inline: component context ---
pub fn unwrap__ref_component_ctx() void {
    // ComponentContext: children only, no custom props
    const Wrapper = struct {
        fn render(ctx: *zx.ComponentContext) zx.Component {
            return (
                <div @allocator={ctx.allocator} class="wrapper">
                    {ctx.children}
                </div>
            );
        }
    };
    _ = Wrapper.render;
}

// --- Reference Inline: component ctx props ---
pub fn unwrap__ref_component_ctx_props() void {
    // ComponentCtx(Props): props and children access
    const CardProps = struct { title: []const u8 };
    const CardCtx = struct {
        fn render(ctx: *zx.ComponentCtx(CardProps)) zx.Component {
            return (
                <article @allocator={ctx.allocator} class="card">
                    <h2>{ctx.props.title}</h2>
                    {ctx.children}
                </article>
            );
        }
    };
    _ = CardCtx.render;
}

// --- Reference Inline: multiline strings ---
pub fn unwrap__ref_multiline_strings() void {
    // Multiline strings use Zig's \\ syntax:
    _ = (
        <pre>
            {
            \\const x = 1;
            \\const y = 2;
            \\const sum = x + y;
        }
        </pre>
    );
}

// --- Reference Inline: comments ---
pub fn unwrap__ref_comments() void {
    // Single-line comments are supported in ZX:
    _ = (
        <div>
            // This is a comment
            <p>Visible content</p>
            // Another comment
        </div>
    );
}

// --- Reference Inline: route ctx ---
pub fn unwrap__ref_route_ctx() void {
    // pub fn GET(ctx: zx.RouteContext) !void {
    //     // ctx.request  - Request details
    //     // ctx.response - Set headers, body, json, etc.
    //     // ctx.socket   - WebSocket upgrade and pub/sub
    //     // ctx.arena    - Request-scoped allocator
    // }
}

// --- Reference Inline: socket ctx ---
pub fn unwrap__ref_socket_ctx() void {
    // pub fn Socket(ctx: zx.SocketContext) !void {
    //     // ctx.socket   - WebSocket interface
    //     // ctx.message  - Received message data
    //     // ctx.data     - Custom data from upgrade
    //     // ctx.arena    - Message-scoped allocator
    // }
}

// --- Reference Inline: component caching basic ---
pub fn unwrap__ref_component_caching_basic() void {
    // Cache for 10 seconds
    _ = (<header @caching="10s" />);

    // Cache for 5 minutes
    _ = (<aside @caching="5m" />);

    // Cache for 1 hour
    _ = (<footer @caching="1h" />);

    // Cache for 1 day
    _ = (<section @caching="1d" />);
}

// --- Reference Inline: component caching key ---
pub fn unwrap__ref_component_caching_key() void {
    // Cache with a custom key for manual invalidation
    _ = (<section @caching="10m:user-profile" />);

    // Cache navigation with key
    _ = (<nav @caching="1h:main-nav" />);
}

