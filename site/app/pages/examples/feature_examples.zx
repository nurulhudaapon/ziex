// --- Reference Inline: cache invalidation ---
pub fn unwrap__ref_cache_invalidation() void {
    // Delete a specific cache entry by key
    _ = zx.cache.del("cmp:user-profile");

    // Delete all entries matching a prefix
    // Useful for invalidating related content
    _ = zx.cache.delPrefix("cmp:user");
}

// --- Learn: state management ---
pub fn Learn__StateDemo(allocator: zx.Allocator) zx.Component {
    return (<Learn__StatePanel @allocator={allocator} @rendering={.client} />);
}

pub fn Learn__StatePanel(ctx: *zx.ComponentCtx(void)) zx.Component {
    const count = ctx.state(i32, 0);
    const title = ctx.state([]const u8, "Hello");
    return (
        <div @allocator={ctx.allocator}>
            <h1>App State: {title.get()}</h1>
            <p>Count: {count.get()}</p>
            <button onclick={count.bind(Learn__incrementCount)}>Increment Count</button>
        </div>
    );
}

fn Learn__incrementCount(value: i32) i32 {
    return value + 1;
}

// --- Learn: api route ---
pub fn Learn__GET(ctx: zx.RouteContext) !void {
    try ctx.response.json(.{ .message = "Hello World!" }, .{});
}

// --- Imports ---
pub fn RenderTest(allocator: zx.Allocator) zx.Component {
    return (
        <div @{allocator}>
            <ControlIf is_admin={true} />
            <ControlIfOptional />
            <ControlIfError />
            <ControlSwitch role={Role.member} />
            <ControlFor items={&.{"One", "Two", "Three"}} />
            <ControlWhile />
            <ControlWhileOptional />
            <ControlWhileError />
            <CacheComponent />
            <Fragment />
            <SpreadProps />
            <DynamicAttr />
            <Client />
        </div>
    );
}

