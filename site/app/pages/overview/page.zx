pub fn Page(ctx: zx.PageContext, app: root.AppCtx) zx.Component {
    return (
        <main @allocator={ctx.arena}>
            <p>{app.port}</p>
            <QuickExample />
        </main>
    );
}

const QuickExample = @import("./../examples/overview.zx").QuickExample;
const zx = @import("zx");
const root = @import("root");